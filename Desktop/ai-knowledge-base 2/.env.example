# ─────────────────────────────────────────────────────────────────────────────
# Cortexa AI — Variables de entorno (plantilla)
#
# 1) Copia este archivo como .env: cp .env.example .env
# 2) Genera valores aleatorios para los marcados como [GENERAR] (ver más abajo).
# 3) NUNCA comitees .env (ya está en .gitignore).
#
# Para generar valores aleatorios seguros:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# ─────────────────────────────────────────────────────────────────────────────

# ── Seguridad / autenticación ────────────────────────────────────────────────
# [GENERAR] Clave secreta para las cookies de sesión. >= 48 chars aleatorios.
COOKIE_SECRET_KEY=

# [GENERAR] Clave de cifrado simétrico Fernet para settings sensibles
# (SMTP password, SSO secrets, connector tokens). Debe ser base64 url-safe 32 bytes.
# Generar con: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SETTINGS_ENCRYPTION_KEY=

# Contraseña inicial del admin. Solo se usa en el primer arranque. Después,
# el admin debe cambiarla obligatoriamente desde la UI.
# Genera una aleatoria con: python3 -c "import secrets; print(secrets.token_urlsafe(20))"
ADMIN_INITIAL_PASSWORD=

# Email del admin inicial.
ADMIN_INITIAL_EMAIL=admin@empresa.com

# ── API REST (FastAPI) ───────────────────────────────────────────────────────
# Lista de orígenes permitidos para CORS, separada por comas.
# Por seguridad NO uses "*". Ejemplo: https://cortexa.empresa.com,https://intranet.empresa.com
CORS_ORIGINS=https://cortexa.local

# ── Ollama / LLM ─────────────────────────────────────────────────────────────
# URL base del servidor Ollama. En docker-compose se usa http://ollama:11434.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Base de datos / Almacenamiento ───────────────────────────────────────────
DB_DIR=./db
DATA_DIR=./data
BACKUPS_DIR=./backups

# ── Límites de subida ────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50

# ── SMTP (opcional — para envío de contraseñas y reset) ──────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Cortexa AI <noreply@empresa.com>
SMTP_TLS=true

# ── Web3Forms (formulario público de demo) ───────────────────────────────────
# Si tienes una landing pública con formulario, pon aquí la access key.
# Obtener en https://web3forms.com (gratis).
WEB3FORMS_ACCESS_KEY=

# ── Streamlit ────────────────────────────────────────────────────────────────
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false
