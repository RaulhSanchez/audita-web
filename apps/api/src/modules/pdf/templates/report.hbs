<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: Arial, Helvetica, sans-serif;
      color: #1e293b;
      background: #fff;
      font-size: 13px;
      line-height: 1.55;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    /* ───────────────── PORTADA ───────────────────────────────────── */
    .cover {
      background: #0f172a;
      color: #fff;
      width: 100%;
      min-height: 1050px;
      padding: 64px 60px 56px;
      page-break-after: always;
      position: relative;
    }

    .cover-glow {
      position: absolute;
      top: -80px;
      right: -80px;
      width: 420px;
      height: 420px;
      background: radial-gradient(circle, rgba(99, 102, 241, .35) 0%, transparent 60%);
      border-radius: 50%;
    }

    .cover-glow2 {
      position: absolute;
      bottom: -60px;
      left: -60px;
      width: 300px;
      height: 300px;
      background: radial-gradient(circle, rgba(139, 92, 246, .2) 0%, transparent 60%);
      border-radius: 50%;
    }

    .cover-inner {
      position: relative;
      z-index: 1;
    }

    .cover-tag {
      display: inline-block;
      border: 1px solid rgba(165, 180, 252, .4);
      color: #a5b4fc;
      padding: 4px 14px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 700;
      margin-bottom: 40px;
    }

    .cover-title {
      font-size: 42px;
      font-weight: 900;
      line-height: 1.1;
      margin-bottom: 10px;
    }

    .cover-sub {
      font-size: 15px;
      color: #94a3b8;
      margin-bottom: 32px;
    }

    .cover-url {
      display: inline-block;
      background: rgba(255, 255, 255, .07);
      border: 1px solid rgba(255, 255, 255, .12);
      padding: 8px 18px;
      border-radius: 8px;
      font-size: 13px;
      color: #e0e7ff;
      margin-bottom: 56px;
      word-break: break-all;
    }

    .cover-score-row {
      display: table;
      width: 100%;
      margin-bottom: 48px;
    }

    .cover-score-left {
      display: table-cell;
      vertical-align: middle;
      width: 200px;
    }

    .cover-score-right {
      display: table-cell;
      vertical-align: middle;
      padding-left: 40px;
    }

    .big-score {
      width: 160px;
      height: 160px;
      border-radius: 50%;
      border: 10px solid rgba(255, 255, 255, .12);
      text-align: center;
      padding-top: 28px;
    }

    .big-score-num {
      font-size: 58px;
      font-weight: 900;
      line-height: 1;
    }

    .big-score-num.green { color: #34d399; }
    .big-score-num.yellow { color: #fbbf24; }
    .big-score-num.red { color: #f87171; }

    .big-score-denom {
      font-size: 14px;
      color: rgba(255, 255, 255, .4);
    }

    .big-score-word {
      font-size: 11px;
      color: rgba(255, 255, 255, .5);
      margin-top: 4px;
      font-weight: 600;
    }

    .cover-score-label {
      font-size: 13px;
      color: #94a3b8;
      margin-bottom: 6px;
    }

    .cover-score-desc {
      font-size: 22px;
      font-weight: 800;
      color: #fff;
      line-height: 1.2;
      margin-bottom: 20px;
    }

    /* Stats inline en portada */
    .cover-stats-row {
      display: table;
      margin-bottom: 0;
    }

    .cover-stat {
      display: table-cell;
      padding-right: 32px;
      vertical-align: top;
    }

    .cover-stat-val {
      font-size: 20px;
      font-weight: 800;
      color: #e0e7ff;
    }

    .cover-stat-lbl {
      font-size: 11px;
      color: #64748b;
    }

    .cover-footer-row {
      display: table;
      width: 100%;
      margin-top: 56px;
    }

    .cover-footer-left {
      display: table-cell;
      vertical-align: bottom;
    }

    .cover-footer-right {
      display: table-cell;
      vertical-align: bottom;
      text-align: right;
    }

    .cover-footer-left p { font-size: 12px; color: #475569; }
    .cover-footer-left strong { color: #94a3b8; display: block; font-size: 13px; }
    .cover-footer-right p { font-size: 12px; color: #475569; }
    .cover-footer-right strong { color: #a5b4fc; display: block; font-size: 14px; font-weight: 700; }

    /* ───────────────── PÁGINAS INTERNAS ─────────────────────────── */
    .page {
      padding: 48px 52px;
      page-break-after: auto;
    }

    .page-break {
      page-break-before: always;
    }

    .section-tag {
      font-size: 10px;
      font-weight: 700;
      color: #6366f1;
      background: #eef2ff;
      display: inline-block;
      padding: 3px 10px;
      border-radius: 4px;
      margin-bottom: 8px;
    }

    h2 {
      font-size: 22px;
      font-weight: 900;
      color: #0f172a;
      margin-bottom: 20px;
    }

    h3 {
      font-size: 14px;
      font-weight: 700;
      color: #1e293b;
    }

    p { color: #475569; line-height: 1.65; }

    /* ───────────── CAJA RESUMEN ──────────────────────────────────── */
    .summary-box {
      background: #f8fafc;
      border: 1px solid #e2e8f0;
      border-left: 4px solid #6366f1;
      border-radius: 0 10px 10px 0;
      padding: 22px 26px;
      margin-bottom: 24px;
      font-size: 13.5px;
      line-height: 1.75;
      color: #334155;
    }

    /* ───────────── STATS TÉCNICAS ────────────────────────────────── */
    .stats-row {
      display: table;
      width: 100%;
      border-collapse: separate;
      border-spacing: 10px 0;
      margin-bottom: 24px;
    }

    .stat-box {
      display: table-cell;
      background: #f8fafc;
      border: 1px solid #e2e8f0;
      border-radius: 10px;
      padding: 14px 16px;
      text-align: center;
      vertical-align: top;
      width: 33%;
    }

    .stat-val {
      font-size: 22px;
      font-weight: 900;
      color: #0f172a;
      line-height: 1.1;
      margin-bottom: 4px;
    }

    .stat-val.warn { color: #d97706; }
    .stat-val.bad  { color: #dc2626; }

    .stat-lbl {
      font-size: 10px;
      font-weight: 600;
      color: #94a3b8;
    }

    /* ───────────── CONTADORES ────────────────────────────────────── */
    .counts-table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 8px 0;
      margin-bottom: 24px;
    }

    .count-box {
      padding: 16px 10px;
      border-radius: 10px;
      text-align: center;
      vertical-align: top;
    }

    .count-box.c-crit { background: #fef2f2; }
    .count-box.c-high { background: #fff7ed; }
    .count-box.c-med  { background: #fffbeb; }
    .count-box.c-low  { background: #eff6ff; }

    .count-n {
      font-size: 32px;
      font-weight: 900;
      line-height: 1;
      margin-bottom: 4px;
    }

    .count-box.c-crit .count-n { color: #dc2626; }
    .count-box.c-high .count-n { color: #ea580c; }
    .count-box.c-med  .count-n { color: #d97706; }
    .count-box.c-low  .count-n { color: #2563eb; }

    .count-l {
      font-size: 11px;
      font-weight: 600;
      color: #64748b;
    }

    /* ───────────── CAJA URGENTE ──────────────────────────────────── */
    .urgent-box {
      background: #fff5f5;
      border: 1px solid #fecaca;
      border-radius: 10px;
      padding: 18px 22px;
      margin-bottom: 24px;
    }

    .urgent-title {
      font-size: 12px;
      font-weight: 700;
      color: #991b1b;
      margin-bottom: 10px;
    }

    .urgent-row {
      padding: 5px 0;
      border-bottom: 1px solid #fee2e2;
      font-size: 13px;
      color: #7f1d1d;
    }

    .urgent-row:last-child { border-bottom: none; }

    /* ───────────── GRID PUNTUACIONES ─────────────────────────────── */
    .scores-table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 10px 0;
      margin-bottom: 24px;
    }

    .score-box {
      background: #fff;
      border: 1px solid #e2e8f0;
      border-radius: 12px;
      padding: 18px 12px;
      text-align: center;
      vertical-align: top;
    }

    .score-area {
      font-size: 10px;
      font-weight: 700;
      color: #94a3b8;
      margin-bottom: 10px;
    }

    .score-val {
      font-size: 40px;
      font-weight: 900;
      line-height: 1;
      margin-bottom: 5px;
    }

    .score-box.green .score-val { color: #059669; }
    .score-box.yellow .score-val { color: #d97706; }
    .score-box.red .score-val { color: #dc2626; }

    .score-qual { font-size: 11px; font-weight: 700; }
    .score-box.green .score-qual { color: #059669; }
    .score-box.yellow .score-qual { color: #d97706; }
    .score-box.red .score-qual { color: #dc2626; }

    /* ───────────── NARRATIVA ─────────────────────────────────────── */
    .narrative-box {
      background: #fafafa;
      border: 1px solid #e2e8f0;
      border-radius: 10px;
      padding: 22px 26px;
      margin-bottom: 24px;
      font-size: 13.5px;
      line-height: 1.8;
      color: #334155;
      white-space: pre-wrap;
    }

    /* ───────────── HALLAZGOS ─────────────────────────────────────── */
    .finding {
      border: 1px solid #e2e8f0;
      border-radius: 12px;
      margin-bottom: 14px;
      overflow: hidden;
      page-break-inside: avoid;
      background: #fff;
    }

    .finding.critical { border-left: 5px solid #dc2626; }
    .finding.high     { border-left: 5px solid #ea580c; }
    .finding.medium   { border-left: 5px solid #d97706; }
    .finding.low      { border-left: 5px solid #2563eb; }

    .finding-head {
      padding: 14px 20px;
      border-bottom: 1px solid #f1f5f9;
    }

    .fh-table {
      width: 100%;
      border-collapse: collapse;
    }

    .fh-badge-cell {
      width: 74px;
      vertical-align: middle;
      padding-right: 14px;
    }

    .fh-title-cell { vertical-align: middle; }

    .badge {
      display: inline-block;
      padding: 3px 9px;
      border-radius: 5px;
      font-size: 9px;
      font-weight: 800;
    }

    .badge.critical { background: #fef2f2; color: #dc2626; }
    .badge.high     { background: #fff7ed; color: #ea580c; }
    .badge.medium   { background: #fffbeb; color: #d97706; }
    .badge.low      { background: #eff6ff; color: #2563eb; }

    .f-title {
      font-size: 14px;
      font-weight: 700;
      color: #0f172a;
    }

    .f-code {
      font-size: 10px;
      color: #cbd5e1;
      margin-top: 1px;
    }

    .finding-body {
      padding: 14px 20px;
    }

    /* Evidence chips */
    .evidence-row {
      margin-bottom: 10px;
    }

    .evidence-chip {
      display: inline-block;
      background: #f1f5f9;
      border: 1px solid #e2e8f0;
      border-radius: 4px;
      padding: 2px 8px;
      font-size: 11px;
      font-weight: 600;
      color: #475569;
      margin-right: 6px;
      margin-bottom: 4px;
    }

    .evidence-chip strong {
      color: #0f172a;
    }

    .impact-tag {
      font-size: 9px;
      font-weight: 800;
      color: #7c3aed;
      margin-bottom: 4px;
      margin-top: 8px;
    }

    .impact-text {
      font-size: 12.5px;
      line-height: 1.65;
      color: #475569;
      margin-bottom: 10px;
    }

    .fix-tag {
      font-size: 9px;
      font-weight: 800;
      color: #059669;
      margin-bottom: 4px;
    }

    .fix-text {
      font-size: 12.5px;
      line-height: 1.65;
      color: #334155;
      background: #f0fdf4;
      border: 1px solid #bbf7d0;
      border-radius: 6px;
      padding: 8px 12px;
    }

    /* ───────────── PLAN DE ACCIÓN ────────────────────────────────── */
    .action-step {
      display: table;
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 14px;
      page-break-inside: avoid;
    }

    .action-num-cell {
      display: table-cell;
      width: 36px;
      vertical-align: top;
      padding-right: 14px;
    }

    .action-num {
      width: 30px;
      height: 30px;
      border-radius: 50%;
      text-align: center;
      font-size: 13px;
      font-weight: 900;
      color: #fff;
      padding-top: 6px;
    }

    .action-num.critical { background: #dc2626; }
    .action-num.high     { background: #ea580c; }
    .action-num.medium   { background: #d97706; }
    .action-num.low      { background: #2563eb; }

    .action-body-cell {
      display: table-cell;
      vertical-align: top;
    }

    .action-title {
      font-size: 13px;
      font-weight: 700;
      color: #0f172a;
      margin-bottom: 4px;
    }

    .action-desc {
      font-size: 12px;
      color: #64748b;
      line-height: 1.6;
    }

    .action-divider {
      border: none;
      border-top: 1px solid #f1f5f9;
      margin: 0 0 14px 50px;
    }

    /* ───────────── PIE DE PÁGINA ─────────────────────────────────── */
    .page-footer {
      margin-top: 36px;
      padding-top: 12px;
      border-top: 1px solid #e2e8f0;
    }

    .pf-table {
      width: 100%;
      border-collapse: collapse;
    }

    .pf-left {
      font-size: 10px;
      color: #94a3b8;
      vertical-align: middle;
    }

    .pf-right {
      font-size: 10px;
      color: #94a3b8;
      vertical-align: middle;
      text-align: right;
    }

    .pf-left strong { color: #6366f1; }

    /* ───────────── PÁGINA CTA ────────────────────────────────────── */
    .cta-page {
      background: #0f172a;
      color: #fff;
      width: 100%;
      min-height: 1050px;
      padding: 72px 60px;
      page-break-before: always;
      position: relative;
    }

    .cta-glow {
      position: absolute;
      top: -80px;
      right: -80px;
      width: 460px;
      height: 460px;
      background: radial-gradient(circle, rgba(99, 102, 241, .28) 0%, transparent 60%);
      border-radius: 50%;
    }

    .cta-inner {
      position: relative;
      z-index: 1;
      max-width: 540px;
    }

    .cta-tag {
      display: inline-block;
      border: 1px solid rgba(165, 180, 252, .4);
      color: #a5b4fc;
      padding: 4px 14px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 700;
      margin-bottom: 28px;
    }

    .cta-h1 {
      font-size: 34px;
      font-weight: 900;
      line-height: 1.2;
      margin-bottom: 18px;
    }

    .cta-h1 span { color: #a5b4fc; }

    .cta-body {
      font-size: 15px;
      color: #94a3b8;
      line-height: 1.75;
      margin-bottom: 36px;
    }

    .cta-items { margin-bottom: 36px; }

    .cta-item {
      padding: 10px 0;
      border-bottom: 1px solid rgba(255, 255, 255, .07);
    }

    .cta-item:last-child { border-bottom: none; }

    .cti-table {
      width: 100%;
      border-collapse: collapse;
    }

    .cti-check {
      width: 22px;
      vertical-align: top;
      color: #34d399;
      font-weight: 900;
      font-size: 13px;
    }

    .cti-text {
      vertical-align: top;
      font-size: 13px;
      color: #e0e7ff;
      line-height: 1.6;
    }

    .cta-contact { margin-bottom: 36px; }

    .cta-contact-line {
      font-size: 13px;
      color: #94a3b8;
      margin-bottom: 8px;
    }

    .cta-contact-line strong { color: #e0e7ff; }

    .cta-hr {
      border: none;
      border-top: 1px solid rgba(255, 255, 255, .1);
      margin-bottom: 28px;
    }

    .author-table {
      width: 100%;
      border-collapse: collapse;
    }

    .author-av-cell {
      width: 56px;
      vertical-align: middle;
      padding-right: 16px;
    }

    .author-av {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: linear-gradient(135deg, #6366f1, #8b5cf6);
      text-align: center;
      padding-top: 10px;
      font-size: 20px;
      font-weight: 900;
      color: #fff;
    }

    .author-info-cell { vertical-align: middle; }

    .author-name {
      font-size: 16px;
      font-weight: 800;
      color: #fff;
    }

    .author-role {
      font-size: 12px;
      color: #64748b;
    }
  </style>
</head>

<body>

  <!-- ═══════════════════ PORTADA ══════════════════════════════════ -->
  <div class="cover">
    <div class="cover-glow"></div>
    <div class="cover-glow2"></div>
    <div class="cover-inner">

      <div class="cover-tag">AuditaWeb &middot; Informe Profesional</div>
      <div class="cover-title">Auditor&iacute;a Web<br>Completa</div>
      <div class="cover-sub">An&aacute;lisis t&eacute;cnico y de negocio con plan de acci&oacute;n</div>
      <div class="cover-url">{{url}}</div>

      <div class="cover-score-row">
        <div class="cover-score-left">
          <div class="big-score">
            <div class="big-score-num {{colorClass globalScore}}">{{globalScore}}</div>
            <div class="big-score-denom">/100</div>
            <div class="big-score-word">{{scoreLabel globalScore}}</div>
          </div>
        </div>
        <div class="cover-score-right">
          <div class="cover-score-label">Puntuaci&oacute;n global</div>
          <div class="cover-score-desc">
            {{#if (gt globalScore 79)}}Tu web est&aacute; en buena forma{{else}}{{#if (gt globalScore 59)}}Hay margen de mejora importante{{else}}Problemas que cuestan clientes{{/if}}{{/if}}
          </div>
          {{#if pageStats}}
          <div class="cover-stats-row">
            <div class="cover-stat">
              <div class="cover-stat-val">{{fmtMs pageStats.responseTimeMs}}</div>
              <div class="cover-stat-lbl">Tiempo de respuesta</div>
            </div>
            <div class="cover-stat">
              <div class="cover-stat-val">{{pageStats.htmlSizeKb}} KB</div>
              <div class="cover-stat-lbl">Peso de la p&aacute;gina</div>
            </div>
            <div class="cover-stat">
              <div class="cover-stat-val">{{totalFindings}}</div>
              <div class="cover-stat-lbl">Problemas detectados</div>
            </div>
          </div>
          {{/if}}
        </div>
      </div>

      <div class="cover-footer-row">
        <div class="cover-footer-left">
          <p><strong>Fecha de an&aacute;lisis</strong>{{date}}</p>
        </div>
        <div class="cover-footer-right">
          <p><strong>Ra&uacute;l Huete</strong>Desarrollador web &middot; zero2dev.es</p>
        </div>
      </div>

    </div>
  </div>

  <!-- ═══════════════════ RESUMEN EJECUTIVO ════════════════════════ -->
  <div class="page">
    <div class="section-tag">01 &mdash; Resumen Ejecutivo</div>
    <h2>Situaci&oacute;n actual de tu web</h2>

    <div class="summary-box">
      Este informe recoge el an&aacute;lisis completo de <b>{{url}}</b> realizado el {{date}}.
      Se han evaluado cinco &aacute;reas: <b>rendimiento, posicionamiento (SEO), seguridad, experiencia m&oacute;vil</b>
      y <b>captaci&oacute;n de clientes</b>.
      La puntuaci&oacute;n global es <b>{{globalScore}}/100</b> &mdash;
      {{#if (gt globalScore 79)}}tu web est&aacute; en buena forma aunque siempre hay margen de mejora.{{else}}{{#if (gt globalScore 59)}}hay problemas que pueden estar fren&aacute;ndote en Google y reduciendo tus conversiones.{{else}}existen problemas serios que probablemente te est&aacute;n costando clientes ahora mismo.{{/if}}{{/if}}
    </div>

    {{#if pageStats}}
    <table class="stats-row">
      <tr>
        <td class="stat-box">
          <div class="stat-val {{#if (gt pageStats.responseTimeMs 1500)}}bad{{else}}{{#if (gt pageStats.responseTimeMs 800)}}warn{{/if}}{{/if}}">{{fmtMs pageStats.responseTimeMs}}</div>
          <div class="stat-lbl">Tiempo de respuesta del servidor</div>
        </td>
        <td class="stat-box">
          <div class="stat-val {{#if (gt pageStats.htmlSizeKb 500)}}bad{{else}}{{#if (gt pageStats.htmlSizeKb 200)}}warn{{/if}}{{/if}}">{{pageStats.htmlSizeKb}} KB</div>
          <div class="stat-lbl">Peso del HTML de la p&aacute;gina</div>
        </td>
        <td class="stat-box">
          <div class="stat-val">{{totalFindings}}</div>
          <div class="stat-lbl">Total de problemas detectados</div>
        </td>
      </tr>
    </table>
    {{/if}}

    <table class="counts-table">
      <tr>
        <td class="count-box c-crit">
          <div class="count-n">{{criticalCount}}</div>
          <div class="count-l">Cr&iacute;ticos</div>
        </td>
        <td class="count-box c-high">
          <div class="count-n">{{highCount}}</div>
          <div class="count-l">Altos</div>
        </td>
        <td class="count-box c-med">
          <div class="count-n">{{mediumCount}}</div>
          <div class="count-l">Medios</div>
        </td>
        <td class="count-box c-low">
          <div class="count-n">{{lowCount}}</div>
          <div class="count-l">Bajos</div>
        </td>
      </tr>
    </table>

    {{#if urgentFindings.length}}
    <div class="urgent-box">
      <div class="urgent-title">&#9888; Problemas que requieren atenci&oacute;n inmediata</div>
      {{#each urgentFindings}}
      <div class="urgent-row">&#9658; {{#if this.title}}{{this.title}}{{else}}{{this.code}}{{/if}}</div>
      {{/each}}
    </div>
    {{/if}}

    <h2 style="margin-top:24px;">Puntuaciones por &aacute;rea</h2>
    <table class="scores-table">
      <tr>
        {{#each scores}}
        <td class="score-box {{colorClass this}}">
          <div class="score-area">{{scoreAreaName @key}}</div>
          <div class="score-val">{{this}}</div>
          <div class="score-qual">{{scoreLabel this}}</div>
        </td>
        {{/each}}
      </tr>
    </table>

    {{#if narrative}}
    <div class="section-tag" style="margin-top:4px;">An&aacute;lisis de impacto</div>
    <h2>Qu&eacute; significa esto para tu negocio</h2>
    <div class="narrative-box">{{stripMd narrative}}</div>
    {{/if}}

    <div class="page-footer">
      <table class="pf-table">
        <tr>
          <td class="pf-left"><strong>AuditaWeb</strong> &middot; Informe confidencial</td>
          <td class="pf-right">{{url}} &middot; {{date}}</td>
        </tr>
      </table>
    </div>
  </div>

  <!-- ═══════════════════ HALLAZGOS DETALLADOS ═════════════════════ -->
  {{#if findings.length}}
  <div class="page page-break">
    <div class="section-tag">02 &mdash; Hallazgos Detallados</div>
    <h2>{{totalFindings}} problemas detectados</h2>

    <p style="margin-bottom:22px; font-size:13px;">
      Ordenados de mayor a menor urgencia. Para cada problema se muestra el impacto real en tu negocio, los datos concretos detectados y c&oacute;mo solucionarlo.
    </p>

    {{#each findings}}
    <div class="finding {{this.severity}}">
      <div class="finding-head">
        <table class="fh-table">
          <tr>
            <td class="fh-badge-cell">
              <span class="badge {{this.severity}}">{{severityLabel this.severity}}</span>
            </td>
            <td class="fh-title-cell">
              <div class="f-title">{{#if this.title}}{{this.title}}{{else}}{{this.code}}{{/if}}</div>
              <div class="f-code">{{this.code}}</div>
            </td>
          </tr>
        </table>
      </div>
      <div class="finding-body">

        {{#if this.evidence}}
        {{#with this.evidence}}
        <div class="evidence-row">
          {{#if longitud}}<span class="evidence-chip">Longitud: <strong>{{longitud}} chars</strong></span>{{/if}}
          {{#if titulo}}<span class="evidence-chip">T&iacute;tulo: <strong>{{titulo}}</strong></span>{{/if}}
          {{#if descripcion}}<span class="evidence-chip">Descripci&oacute;n: <strong>{{descripcion}}</strong></span>{{/if}}
          {{#if sin_alt}}<span class="evidence-chip">Im&aacute;genes sin alt: <strong>{{sin_alt}}</strong></span>{{/if}}
          {{#if total_imagenes}}<span class="evidence-chip">Total im&aacute;genes: <strong>{{total_imagenes}}</strong></span>{{/if}}
          {{#if h1s}}<span class="evidence-chip">H1 detectados: <strong>{{h1s}}</strong></span>{{/if}}
          {{#if telefono_detectado}}<span class="evidence-chip">Tel&eacute;fono: <strong>{{telefono_detectado}}</strong></span>{{/if}}
          {{#if tamanhos_pequenos}}<span class="evidence-chip">Tama&ntilde;os peq.: <strong>{{tamanhos_pequenos}}</strong></span>{{/if}}
          {{#if tiempo_ms}}<span class="evidence-chip">Tiempo: <strong>{{tiempo_ms}} ms</strong></span>{{/if}}
          {{#if umbral_ms}}<span class="evidence-chip">L&iacute;mite: <strong>{{umbral_ms}} ms</strong></span>{{/if}}
          {{#if tamanho_kb}}<span class="evidence-chip">Tama&ntilde;o: <strong>{{tamanho_kb}} KB</strong></span>{{/if}}
          {{#if scripts_externos}}<span class="evidence-chip">Scripts ext.: <strong>{{scripts_externos}}</strong></span>{{/if}}
          {{#if scripts_inline}}<span class="evidence-chip">Scripts inline: <strong>{{scripts_inline}}</strong></span>{{/if}}
          {{#if ejemplos}}<span class="evidence-chip">Recursos: <strong>{{ejemplos}}</strong></span>{{/if}}
          {{#if server}}<span class="evidence-chip">Servidor: <strong>{{server}}</strong></span>{{/if}}
          {{#if url}}<span class="evidence-chip">URL: <strong>{{url}}</strong></span>{{/if}}
          {{#if header}}<span class="evidence-chip">Header: <strong>{{header}}</strong></span>{{/if}}
        </div>
        {{/with}}
        {{/if}}

        {{#if this.businessImpact}}
        <div class="impact-tag">&#9660; POR QU&Eacute; IMPORTA</div>
        <div class="impact-text">{{this.businessImpact}}</div>
        {{/if}}

        {{#if this.fixSuggestion}}
        <div class="fix-tag">&#10003; C&Oacute;MO SOLUCIONARLO</div>
        <div class="fix-text">{{this.fixSuggestion}}</div>
        {{/if}}

      </div>
    </div>
    {{/each}}

    <div class="page-footer">
      <table class="pf-table">
        <tr>
          <td class="pf-left"><strong>AuditaWeb</strong> &middot; Hallazgos detallados</td>
          <td class="pf-right">{{url}} &middot; {{date}}</td>
        </tr>
      </table>
    </div>
  </div>
  {{/if}}

  <!-- ═══════════════════ PLAN DE ACCIÓN ══════════════════════════ -->
  {{#if urgentFindings.length}}
  <div class="page page-break">
    <div class="section-tag">03 &mdash; Plan de Acci&oacute;n</div>
    <h2>Por d&oacute;nde empezar</h2>

    <div class="summary-box" style="margin-bottom:28px;">
      Hemos ordenado los problemas por prioridad de impacto en tu negocio. Empieza por los cr&iacute;ticos y altos: son los que m&aacute;s clientes y visibilidad te est&aacute;n costando ahora mismo.
    </div>

    {{#each urgentFindings}}
    <div class="action-step">
      <div class="action-num-cell">
        <div class="action-num {{this.severity}}">{{add @index 1}}</div>
      </div>
      <div class="action-body-cell">
        <div class="action-title">{{#if this.title}}{{this.title}}{{else}}{{this.code}}{{/if}}
          <span style="font-size:10px;font-weight:600;color:#94a3b8;margin-left:8px;">{{severityLabel this.severity}}</span>
        </div>
        {{#if this.fixSuggestion}}
        <div class="action-desc">{{this.fixSuggestion}}</div>
        {{else}}
        {{#if this.businessImpact}}
        <div class="action-desc">{{this.businessImpact}}</div>
        {{/if}}
        {{/if}}
      </div>
    </div>
    {{#unless @last}}<hr class="action-divider">{{/unless}}
    {{/each}}

    {{#if mediumFindings.length}}
    <h3 style="margin-top:28px;margin-bottom:16px;color:#64748b;">Mejoras adicionales recomendadas</h3>
    {{#each mediumFindings}}
    <div class="action-step">
      <div class="action-num-cell">
        <div class="action-num medium">&#183;</div>
      </div>
      <div class="action-body-cell">
        <div class="action-title" style="color:#475569;">{{#if this.title}}{{this.title}}{{else}}{{this.code}}{{/if}}</div>
        {{#if this.fixSuggestion}}
        <div class="action-desc">{{this.fixSuggestion}}</div>
        {{/if}}
      </div>
    </div>
    {{#unless @last}}<hr class="action-divider">{{/unless}}
    {{/each}}
    {{/if}}

    <div class="page-footer">
      <table class="pf-table">
        <tr>
          <td class="pf-left"><strong>AuditaWeb</strong> &middot; Plan de acci&oacute;n</td>
          <td class="pf-right">{{url}} &middot; {{date}}</td>
        </tr>
      </table>
    </div>
  </div>
  {{/if}}

  <!-- ═══════════════════ CTA ══════════════════════════════════════ -->
  <div class="cta-page">
    <div class="cta-glow"></div>
    <div class="cta-inner">

      <div class="cta-tag">{{#if urgentFindings.length}}04{{else}}03{{/if}} &mdash; Siguiente Paso</div>
      <div class="cta-h1">&iquest;Quieres que arregle<br><span>los problemas cr&iacute;ticos esta semana?</span></div>
      <div class="cta-body">
        Ya sabes qu&eacute; falla y cu&aacute;nto te est&aacute; costando. El <strong>Sprint Quick Wins</strong> es exactamente esto:
        arreglo los {{criticalCount}} problemas cr&iacute;ticos y los de mayor impacto en <strong>5&ndash;7 d&iacute;as</strong>,
        con resultado medible (re-auditor&iacute;a antes/despu&eacute;s incluida).
      </div>

      <!-- Precio destacado -->
      <div style="background:rgba(99,102,241,0.15);border:1px solid rgba(99,102,241,0.4);border-radius:12px;padding:16px 20px;margin:20px 0;display:flex;align-items:center;gap:16px;">
        <div style="flex:1;">
          <div style="font-size:11px;font-weight:800;color:#a5b4fc;letter-spacing:0.08em;text-transform:uppercase;margin-bottom:4px;">Sprint Quick Wins &mdash; 1 semana</div>
          <div style="font-size:22px;font-weight:900;color:#fff;">500&ndash;900 &euro;</div>
          <div style="font-size:11px;color:#94a3b8;margin-top:2px;">Seg&uacute;n n&uacute;mero de problemas. Precio cerrado antes de empezar.</div>
        </div>
        <div style="flex-shrink:0;text-align:center;">
          <div style="font-size:10px;color:#94a3b8;margin-bottom:4px;">Puntuaci&oacute;n actual</div>
          <div style="font-size:28px;font-weight:900;color:#f87171;">{{globalScore}}</div>
          <div style="font-size:9px;color:#94a3b8;">&rarr; objetivo 75+</div>
        </div>
      </div>

      <div class="cta-items">
        <div class="cta-item">
          <table class="cti-table">
            <tr>
              <td class="cti-check">&#10003;</td>
              <td class="cti-text">Corrijo los {{criticalCount}} problemas cr&iacute;ticos + los de mayor impacto en negocio</td>
            </tr>
          </table>
        </div>
        <div class="cta-item">
          <table class="cti-table">
            <tr>
              <td class="cti-check">&#10003;</td>
              <td class="cti-text">Re-auditor&iacute;a final incluida: ves la mejora en puntos medidos</td>
            </tr>
          </table>
        </div>
        <div class="cta-item">
          <table class="cti-table">
            <tr>
              <td class="cti-check">&#10003;</td>
              <td class="cti-text">Entrega en 5&ndash;7 d&iacute;as laborables. Precio cerrado, sin sorpresas</td>
            </tr>
          </table>
        </div>
        <div class="cta-item">
          <table class="cti-table">
            <tr>
              <td class="cti-check">&#10003;</td>
              <td class="cti-text">Sin necesidad de cambiar tu web ni tu proveedor actual</td>
            </tr>
          </table>
        </div>
      </div>

      <!-- Llamada a la acción principal -->
      <div style="background:#4f46e5;border-radius:12px;padding:18px 24px;text-align:center;margin:24px 0 16px;">
        <div style="font-size:15px;font-weight:800;color:#fff;margin-bottom:6px;">
          Reserva 15 minutos &mdash; te explico por d&oacute;nde empezar
        </div>
        <div style="font-size:12px;color:#c7d2fe;margin-bottom:10px;">
          Sin compromiso. En la llamada ves el informe conmigo y decidimos juntos.
        </div>
        <div style="font-size:13px;font-weight:700;color:#a5b4fc;letter-spacing:0.02em;">
          zero2dev.es/llamada
        </div>
      </div>

      <div class="cta-contact">
        <div class="cta-contact-line"><strong>Email:</strong> 92sanchez.raul@gmail.com</div>
        <div class="cta-contact-line"><strong>Web:</strong> zero2dev.es &nbsp;&middot;&nbsp; <strong>Reserva:</strong> zero2dev.es/llamada</div>
      </div>

      <hr class="cta-hr">

      <table class="author-table">
        <tr>
          <td class="author-av-cell">
            <div class="author-av">R</div>
          </td>
          <td class="author-info-cell">
            <div class="author-name">Ra&uacute;l Huete</div>
            <div class="author-role">Arquitecto de Software freelance &middot; Madrid sur &middot; zero2dev.es</div>
          </td>
        </tr>
      </table>

    </div>
  </div>

</body>

</html>
